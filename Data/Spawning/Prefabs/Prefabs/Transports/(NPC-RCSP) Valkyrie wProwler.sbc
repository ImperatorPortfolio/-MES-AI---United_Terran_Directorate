              <CustomName>Programmable Block (AI)</CustomName>
              <ShowOnHUD>false</ShowOnHUD>
              <ShowInTerminal>true</ShowInTerminal>
              <ShowInToolbarConfig>true</ShowInToolbarConfig>
              <ShowInInventory>true</ShowInInventory>
              <NumberInGrid>1</NumberInGrid>
              <Enabled>true</Enabled>
              <Program>List&lt;IMyTerminalBlock&gt; remotes = new List&lt;IMyTerminalBlock&gt;();
void Main(string argument)
{
    GridTerminalSystem.GetBlocksOfType&lt;IMyRemoteControl&gt;(remotes);
    if (remotes.Count &gt; 0)
    {
        var remote = (IMyRemoteControl)remotes[0];
        Vector3D playerPos;
        bool found = remote.GetNearestPlayer(out playerPos);
        if (found)
        {
            double distance = Vector3D.Distance(remote.GetPosition(), playerPos);
            Vector3D targetPos;
            if (distance &lt;= 250)
            {
                // Offset by 75m vertically when within 250m
                targetPos = playerPos + new Vector3D(0, 75, 0);
            }
            else
            {
                // Direct waypoint otherwise
                targetPos = playerPos;
            }
            remote.ClearWaypoints();
            remote.AddWaypoint(targetPos, "Player Waypoint");
            remote.SetAutoPilotEnabled(true);
        }
    }
}</Program>
