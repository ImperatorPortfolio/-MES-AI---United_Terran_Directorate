            <Y>0.0</Y>
            <Z>0.0</Z>
          </Position>
          <Speed>18</Speed>
          <Behaviour>UTD-Behavior-MilitaryCargoShipSG</Behaviour>
        </Prefab>        
      </Prefabs>
    </SpawnGroup>



