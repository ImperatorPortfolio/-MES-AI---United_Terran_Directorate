    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>UTD-Spawn-SpawnSquadronMK1</SubtypeId>
      </Id>
      <Description>

        [MES AI Spawn]

        [UseSpawn:true]
        [StartsReady:true]
        [MaxSpawns:-1]

        [SpawnGroups:UTD-SpawnGroup-SquadronSwifts+Raven]
        [SpawnGroups:UTD-SpawnGroup-SquadronArrowheads]
        [SpawnGroups:UTD-SpawnGroup-SquadronArrowheads]
        [SpawnGroups:UTD-SpawnGroup-SquadronPredators]
        [SpawnGroups:UTD-SpawnGroup-SquadronPredators]
        [SpawnGroups:UTD-SpawnGroup-SquadronPredators+Falcon]

        [MinDistance:100]
        [MaxDistance:1200]
        [MinAltitude:2550]
        [MaxAltitude:3500]

      </Description>

    </EntityComponent>
    
	
    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>UTD-Spawn-SpawnSquadronMK2</SubtypeId>
      </Id>
      <Description>

        [MES AI Spawn]

        [UseSpawn:true]
        [StartsReady:true]
        [MaxSpawns:-1]

        [SpawnGroups:UTD-SpawnGroup-SquadronArrowheads]
        [SpawnGroups:UTD-SpawnGroup-SquadronPredators]
        [SpawnGroups:UTD-SpawnGroup-SquadronPredators]
        [SpawnGroups:UTD-SpawnGroup-SquadronPredators+Falcon]
        [SpawnGroups:UTD-SpawnGroup-SquadronFalcons]
        [SpawnGroups:UTD-SpawnGroup-SquadronFalcons]
        [SpawnGroups:UTD-SpawnGroup-SquadronFalcons+MkII]
        [SpawnGroups:UTD-SpawnGroup-SquadronScythes]
        [SpawnGroups:UTD-SpawnGroup-SquadronWyverns]
        [SpawnGroups:UTD-SpawnGroup-SquadronValkyrieMkVs]

        [MinDistance:100]
        [MaxDistance:1200]
        [MinAltitude:2550]
        [MaxAltitude:3500]

      </Description>

    </EntityComponent>
    
	

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>UTD-Spawn-SpawnSquadronMK3</SubtypeId>
      </Id>
      <Description>

        [MES AI Spawn]

        [UseSpawn:true]
        [StartsReady:true]
        [MaxSpawns:-1]

        [SpawnGroups:UTD-SpawnGroup-SquadronArrowheads]
        [SpawnGroups:UTD-SpawnGroup-SquadronFalcons+MkII]
        [SpawnGroups:UTD-SpawnGroup-SquadronFalcons+MkII]
        [SpawnGroups:UTD-SpawnGroup-SquadronFalconMkIIs]
        [SpawnGroups:UTD-SpawnGroup-SquadronFalconMkIIs]
        [SpawnGroups:UTD-SpawnGroup-SquadronSabers]
        [SpawnGroups:UTD-SpawnGroup-SquadronV207s]        
        [SpawnGroups:UTD-SpawnGroup-SquadronWyvernwScorpions]
        [SpawnGroups:UTD-SpawnGroup-SquadronValkyrieMkVs]

