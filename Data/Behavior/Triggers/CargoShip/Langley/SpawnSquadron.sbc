      </Id>
      <Description>

        [MES AI Action]

        [SpawnEncounter:true]
        [Spawner:UTD-Spawn-SpawnSquadronMK1]

        [UseChatBroadcast:true]
        [ChatData:UTD-Chat-SpawningCarrier]

      </Description>

